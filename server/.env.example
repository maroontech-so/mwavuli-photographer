MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password
NODE_ENV=development
PORT=5000

# Cloudinary (media storage) — REQUIRED in production.
# Render's free filesystem is ephemeral: files written to server/uploads/
# are wiped whenever the service spins down, so media must live in Cloudinary.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=mwavuli
